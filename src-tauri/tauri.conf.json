{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LMU Stats Viewer",
  "version": "2.0.0",
  "identifier": "com.cparfait.lmustatsviewer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LMU Stats Viewer",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "cparfait",
    "copyright": "© 2026 cparfait",
    "category": "Utility",
    "shortDescription": "Statistiques et analyses pour Le Mans Ultimate",
    "longDescription": "Le Mans Ultimate Stats Viewer — visualise tes sessions, analyses tes courses, compare aux temps de la communauté ohne_speed, gère tes setups (.svm). Lit directement les fichiers du jeu, fonctionne 100% en local.",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "wix": {
        "language": ["fr-FR", "en-US"]
      },
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["French", "English"]
      }
    }
  },
  "plugins": {}
}
